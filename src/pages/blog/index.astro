---
import Footer from '../../components/Footer.astro';
import Navigation from '../../components/Navigation.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatBlogDate, getPublishedBlogPosts, truncateText } from '../../utils/blog';

const posts = await getPublishedBlogPosts();
const pageTitle = 'Blog — IT, SEO & Tech-Anleitungen';
const pageDescription =
  'Anleitungen und Erfahrungsberichte zu Docker, KI/AI, Windows Server, SEO und PowerShell von Paul Scholz.';
---

<BaseLayout lang="de" title={pageTitle} description={pageDescription}>
  <Navigation lang="de" />
  <main class="bg-slate-50 pt-32">
    <section class="mx-auto max-w-6xl px-6 py-24 md:px-10 lg:px-12" aria-labelledby="blog-heading">
      <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
        <div class="max-w-3xl">
          <p class="text-sm font-semibold uppercase tracking-[0.24em] text-teal">Blog</p>
          <h1 id="blog-heading" class="mt-4 text-4xl font-semibold tracking-tight text-navy md:text-5xl">
            IT, SEO & Tech-Anleitungen
          </h1>
          <p class="mt-6 text-base leading-8 text-slate-600 md:text-lg">
            Hier teile ich Anleitungen, Praxiserfahrungen und ehrliche Einschätzungen zu Docker,
            KI-gestützten Workflows, Windows Server, PowerShell und lokaler SEO.
          </p>
        </div>

        <a
          href="/en/blog/"
          class="inline-flex items-center rounded-full border border-slate-200 bg-white px-5 py-3 text-sm font-semibold text-navy transition-colors hover:border-teal hover:text-teal"
        >
          English version
        </a>
      </div>

      <div class="mt-16 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {posts.map((post) => (
          <article class="group flex h-full flex-col rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition-all duration-200 hover:-translate-y-1 hover:border-teal/50 hover:shadow-xl hover:shadow-slate-200/70">
            <div class="flex flex-wrap items-center gap-3 text-sm text-slate-500">
              <time datetime={post.data.pubDate.toISOString()}>
                {formatBlogDate(post.data.pubDate, 'de')}
              </time>
              <span class="h-1 w-1 rounded-full bg-slate-300"></span>
              <span>{post.data.tags.length} Tags</span>
            </div>

            <h2 class="mt-5 text-2xl font-semibold tracking-tight text-navy">
              <a href={`/blog/${post.slug}/`} class="transition-colors group-hover:text-teal">
                {post.data.title}
              </a>
            </h2>

            <p class="mt-4 text-base leading-7 text-slate-600">
              {truncateText(post.data.description, 160)}
            </p>

            <div class="mt-6 flex flex-wrap gap-2">
              {post.data.tags.map((tag) => (
                <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-600">
                  #{tag}
                </span>
              ))}
            </div>

            <div class="mt-8 pt-2">
              <a
                href={`/blog/${post.slug}/`}
                class="inline-flex items-center text-sm font-semibold text-teal transition-colors hover:text-navy"
              >
                Beitrag lesen
              </a>
            </div>
          </article>
        ))}
      </div>
    </section>
  </main>
  <Footer lang="de" />
</BaseLayout>
