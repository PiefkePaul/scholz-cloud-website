---
import { render, type CollectionEntry } from 'astro:content';
import Footer from '../../components/Footer.astro';
import Navigation from '../../components/Navigation.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatBlogDate, getPublishedBlogPosts, getReadingTime } from '../../utils/blog';

export async function getStaticPaths() {
  const posts = await getPublishedBlogPosts();

  return posts.map((post, index) => ({
    params: { slug: post.slug },
    props: {
      post,
      newerPost: index > 0 ? posts[index - 1] : null,
      olderPost: index < posts.length - 1 ? posts[index + 1] : null,
    },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
  newerPost: CollectionEntry<'blog'> | null;
  olderPost: CollectionEntry<'blog'> | null;
}

const { post, newerPost, olderPost } = Astro.props;
const { Content } = await render(post);

const pageTitle = `${post.data.title} | Paul Scholz`;
const pageDescription = post.data.description;
const readingTime = getReadingTime(post.body);
---

<BaseLayout
  lang="de"
  title={pageTitle}
  description={pageDescription}
  ogImage={post.data.image}
  ogType="article"
  schemaType="blogpost"
  datePublished={post.data.pubDate}
  dateModified={post.data.updatedDate ?? post.data.pubDate}
>
  <Navigation lang="de" />
  <main class="bg-slate-50 pt-32">
    <section class="mx-auto max-w-5xl px-6 py-16 md:px-10 lg:px-12">
      <a
        href="/blog/"
        class="inline-flex items-center text-sm font-semibold text-teal transition-colors hover:text-navy"
      >
        Zurück zum Blog
      </a>

      <article class="mt-8 overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-sm">
        <header class="border-b border-slate-200 px-6 py-10 md:px-10">
          <div class="flex flex-wrap items-center gap-3 text-sm text-slate-500">
            <time datetime={post.data.pubDate.toISOString()}>
              {formatBlogDate(post.data.pubDate, 'de')}
            </time>
            <span class="h-1 w-1 rounded-full bg-slate-300"></span>
            <span>{readingTime} Min. Lesezeit</span>
            {post.data.updatedDate && (
              <>
                <span class="h-1 w-1 rounded-full bg-slate-300"></span>
                <span>Aktualisiert am {formatBlogDate(post.data.updatedDate, 'de')}</span>
              </>
            )}
          </div>

          <h1 class="mt-6 text-4xl font-semibold tracking-tight text-navy md:text-5xl">
            {post.data.title}
          </h1>
          <p class="mt-5 max-w-3xl text-lg leading-8 text-slate-600">{post.data.description}</p>

          <div class="mt-6 flex flex-wrap gap-2">
            {post.data.tags.map((tag) => (
              <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-600">
                #{tag}
              </span>
            ))}
          </div>
        </header>

        <div class="px-6 py-10 md:px-10 md:py-12">
          <div class="prose prose-slate max-w-none
            prose-headings:text-navy prose-headings:font-semibold prose-headings:tracking-tight
            prose-h2:text-2xl prose-h2:mt-12 prose-h2:mb-4 prose-h2:pb-3 prose-h2:border-b prose-h2:border-slate-200
            prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
            prose-p:text-slate-700 prose-p:leading-8
            prose-li:text-slate-700 prose-li:leading-8
            prose-a:text-teal prose-a:no-underline prose-a:font-medium hover:prose-a:text-navy
            prose-strong:text-navy prose-strong:font-semibold
            prose-code:text-sky-700 prose-code:bg-sky-50 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-sm prose-code:font-mono prose-code:before:content-none prose-code:after:content-none
            prose-pre:overflow-x-auto prose-pre:rounded-2xl prose-pre:border prose-pre:border-slate-800 prose-pre:bg-slate-950 prose-pre:text-slate-100 prose-pre:text-sm prose-pre:leading-7
            prose-img:rounded-2xl prose-img:shadow-md
            prose-blockquote:border-l-4 prose-blockquote:border-teal prose-blockquote:bg-teal/5 prose-blockquote:rounded-r-2xl prose-blockquote:px-6 prose-blockquote:py-4 prose-blockquote:not-italic prose-blockquote:text-slate-700
            prose-blockquote:before:content-none prose-blockquote:after:content-none
            prose-table:text-sm prose-th:bg-slate-100 prose-th:text-navy prose-th:font-semibold
            prose-td:text-slate-700
            prose-hr:border-slate-200 prose-hr:my-10">
            <Content />
          </div>
        </div>

        <div class="border-t border-slate-200 bg-slate-50 px-6 py-8 md:px-10">
          <div class="flex flex-col items-center gap-4 text-center sm:flex-row sm:text-left">
            <img
              src="/images/paul-scholz.jpg"
              alt="Paul Scholz"
              width="56"
              height="56"
              class="h-14 w-14 rounded-full object-cover ring-2 ring-teal/30 shrink-0"
            />
            <div>
              <p class="font-semibold text-navy">Paul Scholz</p>
              <p class="text-sm text-slate-600 mt-0.5">IT-Administrator &amp; SEO-Berater · Enterprise Hyper-V/SCVMM · Docker Homelab · Lokale SEO</p>
            </div>
          </div>
        </div>
      </article>

      {(newerPost || olderPost) && (
        <nav class="mt-10 grid gap-4 md:grid-cols-2" aria-label="Beitragsnavigation">
          {newerPost ? (
            <a
              href={`/blog/${newerPost.slug}/`}
              class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition-colors hover:border-teal/50"
            >
              <p class="text-sm font-semibold text-teal">Neuerer Beitrag</p>
              <p class="mt-3 text-xl font-semibold tracking-tight text-navy">{newerPost.data.title}</p>
            </a>
          ) : (
            <div></div>
          )}

          {olderPost && (
            <a
              href={`/blog/${olderPost.slug}/`}
              class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition-colors hover:border-teal/50"
            >
              <p class="text-sm font-semibold text-teal">Älterer Beitrag</p>
              <p class="mt-3 text-xl font-semibold tracking-tight text-navy">{olderPost.data.title}</p>
            </a>
          )}
        </nav>
      )}
    </section>
  </main>
  <Footer lang="de" />
</BaseLayout>
