---
import { render, type CollectionEntry } from 'astro:content';
import Footer from '../../../components/Footer.astro';
import Navigation from '../../../components/Navigation.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { formatBlogDate, getPublishedBlogPosts, getReadingTime } from '../../../utils/blog';

export async function getStaticPaths() {
  const posts = await getPublishedBlogPosts();

  return posts.map((post, index) => ({
    params: { slug: post.slug },
    props: {
      post,
      newerPost: index > 0 ? posts[index - 1] : null,
      olderPost: index < posts.length - 1 ? posts[index + 1] : null,
    },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
  newerPost: CollectionEntry<'blog'> | null;
  olderPost: CollectionEntry<'blog'> | null;
}

const { post, newerPost, olderPost } = Astro.props;
const { Content } = await render(post);

const title = post.data.titleEn ?? post.data.title;
const description = post.data.descriptionEn ?? post.data.description;
const pageTitle = `${title} | Paul Scholz`;
const readingTime = getReadingTime(post.body);
---

<BaseLayout
  lang="en"
  title={pageTitle}
  description={description}
  ogImage={post.data.image}
  ogType="article"
  schemaType="blogpost"
  datePublished={post.data.pubDate}
  dateModified={post.data.updatedDate ?? post.data.pubDate}
>
  <Navigation lang="en" />
  <main class="bg-slate-50 pt-32">
    <section class="mx-auto max-w-5xl px-6 py-16 md:px-10 lg:px-12">
      <a
        href="/en/blog/"
        class="inline-flex items-center text-sm font-semibold text-teal transition-colors hover:text-navy"
      >
        Back to blog
      </a>

      <article class="mt-8 overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-sm">
        <header class="border-b border-slate-200 px-6 py-10 md:px-10">
          <div class="flex flex-wrap items-center gap-3 text-sm text-slate-500">
            <time datetime={post.data.pubDate.toISOString()}>
              {formatBlogDate(post.data.pubDate, 'en')}
            </time>
            <span class="h-1 w-1 rounded-full bg-slate-300"></span>
            <span>{readingTime} min read</span>
            {post.data.updatedDate && (
              <>
                <span class="h-1 w-1 rounded-full bg-slate-300"></span>
                <span>Updated {formatBlogDate(post.data.updatedDate, 'en')}</span>
              </>
            )}
          </div>

          <h1 class="mt-6 text-4xl font-semibold tracking-tight text-navy md:text-5xl">{title}</h1>
          <p class="mt-5 max-w-3xl text-lg leading-8 text-slate-600">{description}</p>

          <div class="mt-6 flex flex-wrap gap-2">
            {post.data.tags.map((tag) => (
              <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-600">
                #{tag}
              </span>
            ))}
          </div>
        </header>

        <div class="px-6 py-10 md:px-10 md:py-12">
          <div class="prose prose-slate max-w-none prose-headings:text-navy prose-a:text-teal prose-a:no-underline hover:prose-a:text-navy prose-strong:text-navy prose-code:text-sky-700 prose-code:before:content-none prose-code:after:content-none prose-pre:overflow-x-auto prose-pre:rounded-2xl prose-pre:border prose-pre:border-slate-800 prose-pre:bg-slate-950 prose-pre:text-slate-100 prose-img:rounded-2xl prose-blockquote:border-teal prose-blockquote:text-slate-700">
            <Content />
          </div>
        </div>
      </article>

      {(newerPost || olderPost) && (
        <nav class="mt-10 grid gap-4 md:grid-cols-2" aria-label="Post navigation">
          {newerPost ? (
            <a
              href={`/en/blog/${newerPost.slug}/`}
              class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition-colors hover:border-teal/50"
            >
              <p class="text-sm font-semibold text-teal">Newer post</p>
              <p class="mt-3 text-xl font-semibold tracking-tight text-navy">
                {newerPost.data.titleEn ?? newerPost.data.title}
              </p>
            </a>
          ) : (
            <div></div>
          )}

          {olderPost && (
            <a
              href={`/en/blog/${olderPost.slug}/`}
              class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition-colors hover:border-teal/50"
            >
              <p class="text-sm font-semibold text-teal">Older post</p>
              <p class="mt-3 text-xl font-semibold tracking-tight text-navy">
                {olderPost.data.titleEn ?? olderPost.data.title}
              </p>
            </a>
          )}
        </nav>
      )}
    </section>
  </main>
  <Footer lang="en" />
</BaseLayout>
