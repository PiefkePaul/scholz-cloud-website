---
interface Props {
  lang?: 'de' | 'en';
}

const { lang = 'de' } = Astro.props;
const isEnglish = lang === 'en';

const content = isEnglish
  ? {
      headline: 'IT Expert. SEO Consultant. Problem Solver.',
      subheadline:
        'I help businesses optimize their digital infrastructure and increase their online visibility.',
      primaryCta: 'Discover Services',
      secondaryCta: 'Get in Touch',
      primaryHref: '#services',
      secondaryHref: '#contact',
      eyebrow: 'Infrastructure, automation and visibility'
    }
  : {
      headline: 'IT-Experte. SEO-Berater. Problemlöser.',
      subheadline:
        'Ich helfe Unternehmen, ihre digitale Infrastruktur zu optimieren und online sichtbarer zu werden.',
      primaryCta: 'Leistungen entdecken',
      secondaryCta: 'Kontakt aufnehmen',
      primaryHref: '#leistungen',
      secondaryHref: '#kontakt',
      eyebrow: 'Infrastruktur, Automatisierung und digitale Sichtbarkeit'
    };
---

<section
  class="relative isolate overflow-hidden bg-navy text-white"
  aria-labelledby="hero-heading"
>
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,_rgba(14,165,233,0.22),_transparent_34%),radial-gradient(circle_at_bottom_right,_rgba(56,189,248,0.16),_transparent_28%)]"></div>
  <div class="absolute inset-0 opacity-20 [background-image:radial-gradient(circle,_rgba(255,255,255,0.2)_1px,_transparent_1px)] [background-size:24px_24px]"></div>
  <div class="absolute inset-x-0 bottom-0 h-32 bg-gradient-to-t from-navy to-transparent"></div>

  <div class="relative mx-auto flex min-h-screen max-w-6xl flex-col-reverse items-center justify-center gap-12 px-6 pb-20 pt-32 md:flex-row md:justify-between md:gap-16 md:px-10 lg:px-12">
    <div class="max-w-2xl text-center md:text-left">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-teal motion-safe:animate-fade-in">
        {content.eyebrow}
      </p>
      <h1
        id="hero-heading"
        class="mt-6 text-balance text-4xl font-semibold tracking-tight text-white motion-safe:animate-fade-up sm:text-5xl lg:text-6xl"
      >
        {content.headline}
      </h1>
      <p class="mt-6 max-w-xl text-lg leading-8 text-slate-300 motion-safe:animate-fade-up [animation-delay:120ms]">
        {content.subheadline}
      </p>

      <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row md:items-start">
        <a
          href={content.primaryHref}
          class="inline-flex items-center justify-center rounded-full bg-teal px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-teal/25 transition-transform duration-200 hover:-translate-y-0.5 hover:bg-sky-500"
        >
          {content.primaryCta}
        </a>
        <a
          href={content.secondaryHref}
          class="inline-flex items-center justify-center rounded-full border border-white/15 bg-white/5 px-6 py-3 text-sm font-semibold text-white transition-colors duration-200 hover:border-white/25 hover:bg-white/10"
        >
          {content.secondaryCta}
        </a>
      </div>
    </div>

    <div class="relative flex flex-col items-center gap-5">
      <div class="absolute -inset-6 rounded-full bg-teal/15 blur-3xl"></div>
      <div class="relative overflow-hidden rounded-full border border-white/10 bg-white/5 p-3 shadow-2xl shadow-black/30 motion-safe:animate-float-soft">
        <img
          src="/images/paul-scholz.jpg"
          alt="Paul Scholz"
          width="200"
          height="200"
          loading="eager"
          decoding="async"
          class="h-[200px] w-[200px] rounded-full object-cover object-center ring-4 ring-teal/40 md:h-[240px] md:w-[240px]"
        />
      </div>
      <p class="text-sm font-medium tracking-wide text-slate-300">
        Paul Scholz
      </p>
    </div>
  </div>
</section>
