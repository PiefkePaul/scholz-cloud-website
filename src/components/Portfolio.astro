---
interface Props {
  lang?: 'de' | 'en';
}

const { lang = 'de' } = Astro.props;
const isEnglish = lang === 'en';

const projects = isEnglish
  ? [
      {
        title: 'GitHub Profile',
        name: 'piefkepaul',
        description:
          'Open source repositories, tooling experiments and automation projects for infrastructure and web workflows.',
        href: 'https://github.com/PiefkePaul',
        cta: 'Open GitHub',
        icon: 'github'
      },
      {
        title: 'Docker Hub',
        name: 'piefkepaul',
        description:
          'Published Docker images for practical self-hosting and automation use cases.',
        href: 'https://hub.docker.com/r/piefkepaul/',
        cta: 'View Images',
        icon: 'docker'
      },
      {
        title: 'More coming soon',
        name: 'In progress',
        description:
          'Additional case studies, freelance builds and open source releases will be added here.',
        icon: 'spark'
      }
    ]
  : [
      {
        title: 'GitHub Profil',
        name: 'piefkepaul',
        description:
          'Open-Source-Repositories, Tooling-Experimente und Automatisierungsprojekte für Infrastruktur- und Web-Workflows.',
        href: 'https://github.com/PiefkePaul',
        cta: 'GitHub öffnen',
        icon: 'github'
      },
      {
        title: 'Docker Hub',
        name: 'piefkepaul',
        description:
          'Veröffentlichte Docker-Images für praxisnahe Self-Hosting- und Automatisierungs-Szenarien.',
        href: 'https://hub.docker.com/r/piefkepaul/',
        cta: 'Images ansehen',
        icon: 'docker'
      },
      {
        title: 'Mehr folgt',
        name: 'In Vorbereitung',
        description:
          'Weitere Case Studies, Freelance-Projekte und Open-Source-Veröffentlichungen werden hier ergänzt.',
        icon: 'spark'
      }
    ];

const iconPath = {
  github:
    'M12 2C6.48 2 2 6.59 2 12.24c0 4.52 2.87 8.36 6.84 9.72.5.09.68-.22.68-.48 0-.24-.01-1.03-.01-1.87-2.78.62-3.37-1.2-3.37-1.2-.46-1.19-1.11-1.5-1.11-1.5-.91-.64.07-.63.07-.63 1 .07 1.54 1.05 1.54 1.05.9 1.57 2.35 1.12 2.92.86.09-.67.35-1.12.63-1.37-2.22-.26-4.56-1.14-4.56-5.09 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.31.1-2.73 0 0 .84-.28 2.75 1.05A9.36 9.36 0 0 1 12 6.84c.85 0 1.7.12 2.49.35 1.91-1.33 2.74-1.05 2.74-1.05.55 1.42.2 2.47.1 2.73.64.72 1.03 1.63 1.03 2.75 0 3.96-2.34 4.82-4.57 5.08.36.32.67.95.67 1.92 0 1.39-.01 2.5-.01 2.84 0 .27.18.58.69.48A10.28 10.28 0 0 0 22 12.24C22 6.59 17.52 2 12 2Z',
  docker:
    'M4 13.5h2.4v2.3H4v-2.3Zm2.9 0h2.4v2.3H6.9v-2.3Zm2.9 0h2.4v2.3H9.8v-2.3Zm2.9 0h2.4v2.3h-2.4v-2.3Zm-5.8-2.9h2.4v2.3H7.8v-2.3Zm2.9 0h2.4v2.3h-2.4v-2.3Zm2.9 0h2.4v2.3h-2.4v-2.3Zm-5.8-2.9h2.4V10H7.8V7.7Zm2.9 0h2.4V10h-2.4V7.7Zm7.7 4.7c-.3 2.4-1.9 4.4-4.2 5.3-1 .4-2.2.6-3.5.5-2.9-.2-5.4-2.2-6.1-5 .7.5 1.7.7 2.7.7h.5c.4 0 .8-.3.8-.8v-5c0-.4.3-.8.8-.8h.6v-1c0-.8.7-1.5 1.5-1.5h1V8h.9V6.4c0-.8.7-1.5 1.5-1.5h1v2.4h.9v5.1h.8c.9 0 1.8-.2 2.6-.7Z',
  spark:
    'M12 3 9.8 8.4 4 10.1l4.1 4L7.1 20 12 17.1 16.9 20l-1-5.9 4.1-4-5.8-1.7L12 3Z'
};
---

<section id="portfolio" class="bg-[#0c1322] py-24 sm:py-28" aria-labelledby="portfolio-heading">
  <div class="mx-auto max-w-6xl px-6 md:px-10 lg:px-12">
    <p class="text-sm font-semibold uppercase tracking-[0.24em] text-teal">
      {isEnglish ? 'Selected work' : 'Ausgewählte Arbeit'}
    </p>
    <h2 id="portfolio-heading" class="mt-4 text-3xl font-semibold tracking-tight text-white sm:text-4xl">
      {isEnglish ? 'Projects & Open Source' : 'Projekte & Open Source'}
    </h2>
    <p class="mt-4 max-w-2xl text-base leading-7 text-white/50">
      {isEnglish ? 'More code and ongoing experiments live on my ' : 'Mehr Code und laufende Experimente finden Sie auf meinem '}
      <a
        href="https://github.com/PiefkePaul"
        target="_blank"
        rel="noopener noreferrer"
        class="font-semibold text-teal hover:text-sky-400"
      >
        GitHub
      </a>
      .
    </p>

    <div class="mt-12 grid gap-6 lg:grid-cols-3">
      {projects.map((project) => (
        <article class="flex h-full flex-col rounded-[2rem] border border-white/[0.08] bg-white/[0.03] p-8 transition-all hover:border-teal/30">
          <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-teal/10 text-teal">
            <svg viewBox="0 0 24 24" fill="currentColor" class="h-7 w-7">
              <path d={iconPath[project.icon]}></path>
            </svg>
          </div>
          <h3 class="mt-6 text-2xl font-semibold text-white">{project.title}</h3>
          {project.name !== 'In progress' && project.name !== 'In Vorbereitung' && (
            <p class="mt-1 text-sm text-slate-400">{project.name}</p>
          )}
          <p class="mt-4 flex-1 text-sm leading-7 text-white/45">
            {project.description}
          </p>

          {project.href ? (
            <a
              href={project.href}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-8 inline-flex w-fit items-center gap-2 rounded-full border border-white/[0.12] px-4 py-2 text-sm font-semibold text-white/70 transition-colors hover:border-teal hover:text-teal"
            >
              {project.cta}
              <span aria-hidden="true">↗</span>
            </a>
          ) : (
            <span class="mt-8 inline-flex w-fit items-center rounded-full border border-white/[0.08] bg-white/[0.04] px-4 py-2 text-sm font-semibold text-white/40">
              {isEnglish ? 'Coming soon' : 'Demnächst'}
            </span>
          )}
        </article>
      ))}
    </div>
  </div>
</section>
