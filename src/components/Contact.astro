---
interface Props {
  lang?: 'de' | 'en';
}

const { lang = 'de' } = Astro.props;
const isEnglish = lang === 'en';

const content = isEnglish
  ? {
      id: 'contact',
      title: 'Get in Touch',
      subtitle:
        'I am happy to hear from you about projects, collaborations or simply for an exchange.',
      name: 'Name',
      email: 'E-Mail',
      subject: 'Subject',
      message: 'Message',
      submit: 'Send Request',
      success:
        'Thank you! Your message has been sent. I will get back to you as soon as possible.',
      error: 'Please fill in all required fields.',
      direct: 'Direct contact',
      directEmail: 'kontakt@wichtige.email',
      responseTime: 'I usually respond within 1–2 business days.',
      helpMe: 'Most helpful: a brief description of the situation, what is envisioned, and whether there is a timeline.',
      linkedIn: 'https://www.linkedin.com/in/p-scholz/',
    }
  : {
      id: 'kontakt',
      title: 'Kontakt aufnehmen',
      subtitle:
        'Ich freue mich über Anfragen zu Projekten, Kooperationen oder einfach zum Austausch.',
      name: 'Name',
      email: 'E-Mail',
      subject: 'Betreff',
      message: 'Nachricht',
      submit: 'Anfrage senden',
      success:
        'Vielen Dank! Ihre Nachricht wurde gesendet. Ich melde mich so schnell wie möglich.',
      error: 'Bitte alle Pflichtfelder ausfüllen.',
      direct: 'Direkter Kontakt',
      directEmail: 'kontakt@wichtige.email',
      responseTime: 'Ich antworte in der Regel innerhalb von 1–2 Werktagen.',
      helpMe: 'Am hilfreichsten: eine kurze Beschreibung der Situation, was vorgestellt wird, und ob es einen Zeitrahmen gibt.',
      linkedIn: 'https://www.linkedin.com/in/p-scholz/',
    };
---

<section
  id={content.id}
  class="relative isolate overflow-hidden bg-navy py-24 text-white sm:py-28"
  aria-labelledby={`${content.id}-heading`}
>
  <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_left,_rgba(14,165,233,0.18),_transparent_30%),radial-gradient(circle_at_bottom_right,_rgba(15,23,42,0.08),_transparent_30%)]"></div>
  <div class="mx-auto grid max-w-6xl gap-10 px-6 md:px-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start lg:px-12">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-teal">
        {isEnglish ? 'Contact' : 'Kontakt'}
      </p>
      <h2 id={`${content.id}-heading`} class="mt-4 text-3xl font-semibold tracking-tight sm:text-4xl">
        {content.title}
      </h2>
      <p class="mt-5 max-w-xl text-base leading-8 text-slate-300">
        {content.subtitle}
      </p>

      <div class="mt-10 rounded-[2rem] border border-white/10 bg-white/5 p-6 backdrop-blur">
        <h3 class="text-lg font-semibold text-white">{content.direct}</h3>
        <dl class="mt-5 space-y-4 text-sm text-slate-300">
          <div>
            <dt class="font-semibold text-white">E-Mail</dt>
            <dd class="mt-1">
              <a
                href={`mailto:${content.directEmail}`}
                class="inline-flex items-center gap-2 text-sm font-medium text-teal hover:text-sky-400 transition-colors"
              >
                <svg aria-hidden="true" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
                </svg>
                {content.directEmail}
              </a>
              <p class="mt-4 text-xs text-slate-400">{content.responseTime}</p>
              <p class="mt-2 text-xs text-slate-400 italic">{content.helpMe}</p>
            </dd>
          </div>
          <div>
            <dt class="font-semibold text-white">GitHub</dt>
            <dd class="mt-1">
              <a
                href="https://github.com/PiefkePaul"
                target="_blank"
                rel="noopener noreferrer"
                class="text-[#58a6ff] hover:text-[#79c0ff] transition-colors"
              >
                github.com/piefkepaul
              </a>
            </dd>
          </div>
          <div>
            <dt class="font-semibold text-white">LinkedIn</dt>
            <dd class="mt-1">
              <a
                href={content.linkedIn}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 text-sm font-medium text-blue-400 hover:text-blue-300 transition-colors"
              >
                <svg aria-hidden="true" class="h-4 w-4 fill-current" viewBox="0 0 24 24">
                  <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>
                </svg>
                linkedin.com/in/p-scholz
              </a>
            </dd>
          </div>
        </dl>
      </div>
    </div>

    <form
      class="contact-form rounded-[2rem] bg-white p-8 text-slate-900 shadow-2xl shadow-black/20 ring-1 ring-slate-200"
      data-contact-form
      data-lang={lang}
      novalidate
      aria-label={isEnglish ? 'Contact form' : 'Kontaktformular'}
    >

      <div class="grid gap-5 sm:grid-cols-2">
        <label class="block">
          <span class="mb-2 block text-sm font-medium text-slate-700">{content.name}</span>
          <input
            type="text"
            name="name"
            required
            class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-teal focus:ring-2 focus:ring-teal/30"
          />
        </label>
        <label class="block">
          <span class="mb-2 block text-sm font-medium text-slate-700">{content.email}</span>
          <input
            type="email"
            name="email"
            required
            class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-teal focus:ring-2 focus:ring-teal/30"
          />
        </label>
      </div>

      <label class="mt-5 block">
        <span class="mb-2 block text-sm font-medium text-slate-700">{content.subject}</span>
        <input
          type="text"
          name="subject"
          required
          class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-teal focus:ring-2 focus:ring-teal/30"
        />
      </label>

      <label class="mt-5 block">
        <span class="mb-2 block text-sm font-medium text-slate-700">{content.message}</span>
        <textarea
          name="message"
          rows="6"
          required
          class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-teal focus:ring-2 focus:ring-teal/30"
        ></textarea>
      </label>

      <p class="form-feedback-success mt-5 hidden rounded-2xl bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-700">
        {content.success}
      </p>
      <p class="form-feedback-error mt-5 hidden rounded-2xl bg-rose-50 px-4 py-3 text-sm font-medium text-rose-700">
        {content.error}
      </p>

      <button
        type="submit"
        data-submit-btn
        class="mt-6 inline-flex items-center justify-center gap-2 rounded-full bg-navy px-6 py-3 text-sm font-semibold text-white transition-all duration-200 hover:-translate-y-0.5 hover:bg-slate-800 disabled:opacity-60 disabled:cursor-not-allowed disabled:translate-y-0"
      >
        <span data-btn-label>{content.submit}</span>
        <svg data-btn-spinner class="hidden h-4 w-4 animate-spin" viewBox="0 0 24 24" fill="none">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
        </svg>
      </button>
    </form>
  </div>
</section>

<style>
  .contact-form.success .form-feedback-success {
    display: block;
  }

  .contact-form.has-error .form-feedback-error {
    display: block;
  }
</style>

<script is:inline>
  const contactForm = document.querySelector('[data-contact-form]');

  if (contactForm instanceof HTMLFormElement) {
    const successMsg = contactForm.querySelector('.form-feedback-success');
    const errorMsg = contactForm.querySelector('.form-feedback-error');
    const submitBtn = contactForm.querySelector('[data-submit-btn]');
    const btnLabel = contactForm.querySelector('[data-btn-label]');
    const btnSpinner = contactForm.querySelector('[data-btn-spinner]');

    // Inline validation feedback
    contactForm.addEventListener('input', () => {
      if (contactForm.checkValidity()) {
        contactForm.classList.remove('has-error');
        if (errorMsg) errorMsg.classList.add('hidden');
      }
    });

    contactForm.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Validate
      if (!contactForm.checkValidity()) {
        contactForm.classList.add('has-error');
        if (errorMsg) errorMsg.classList.remove('hidden');
        // Focus first invalid field
        const firstInvalid = contactForm.querySelector(':invalid');
        if (firstInvalid) firstInvalid.focus();
        return;
      }

      // Show loading state
      if (submitBtn) submitBtn.disabled = true;
      if (btnLabel) btnLabel.textContent = '…';
      if (btnSpinner) btnSpinner.classList.remove('hidden');
      if (errorMsg) errorMsg.classList.add('hidden');

      try {
        const response = await fetch('https://formspree.io/f/xykbqngy', {
          method: 'POST',
          body: new FormData(contactForm),
          headers: { Accept: 'application/json' }
        });

        const data = await response.json();

        if (response.ok && data.ok) {
          // Success
          contactForm.reset();
          if (successMsg) successMsg.classList.remove('hidden');
          if (submitBtn) submitBtn.classList.add('hidden');
        } else {
          throw new Error('Formspree error');
        }
      } catch {
        if (errorMsg) errorMsg.classList.remove('hidden');
        if (submitBtn) submitBtn.disabled = false;
        if (btnLabel) btnLabel.textContent = contactForm.dataset.lang === 'en' ? 'Send Request' : 'Anfrage senden';
        if (btnSpinner) btnSpinner.classList.add('hidden');
      }
    });
  }
</script>
