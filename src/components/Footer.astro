---
interface Props {
  lang?: 'de' | 'en';
}

const { lang = 'de' } = Astro.props;
const isEnglish = lang === 'en';

const socials = [
  {
    name: 'GitHub',
    href: 'https://github.com/PiefkePaul',
    path: 'M12 2C6.48 2 2 6.59 2 12.24c0 4.52 2.87 8.36 6.84 9.72.5.09.68-.22.68-.48 0-.24-.01-1.03-.01-1.87-2.78.62-3.37-1.2-3.37-1.2-.46-1.19-1.11-1.5-1.11-1.5-.91-.64.07-.63.07-.63 1 .07 1.54 1.05 1.54 1.05.9 1.57 2.35 1.12 2.92.86.09-.67.35-1.12.63-1.37-2.22-.26-4.56-1.14-4.56-5.09 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.31.1-2.73 0 0 .84-.28 2.75 1.05A9.36 9.36 0 0 1 12 6.84c.85 0 1.7.12 2.49.35 1.91-1.33 2.74-1.05 2.74-1.05.55 1.42.2 2.47.1 2.73.64.72 1.03 1.63 1.03 2.75 0 3.96-2.34 4.82-4.57 5.08.36.32.67.95.67 1.92 0 1.39-.01 2.5-.01 2.84 0 .27.18.58.69.48A10.28 10.28 0 0 0 22 12.24C22 6.59 17.52 2 12 2Z'
  },
  {
    name: 'Docker Hub',
    href: 'https://hub.docker.com/r/piefkepaul/',
    path: 'M4 13.5h2.4v2.3H4v-2.3Zm2.9 0h2.4v2.3H6.9v-2.3Zm2.9 0h2.4v2.3H9.8v-2.3Zm2.9 0h2.4v2.3h-2.4v-2.3Zm-5.8-2.9h2.4v2.3H7.8v-2.3Zm2.9 0h2.4v2.3h-2.4v-2.3Zm2.9 0h2.4v2.3h-2.4v-2.3Zm-5.8-2.9h2.4V10H7.8V7.7Zm2.9 0h2.4V10h-2.4V7.7Zm7.7 4.7c-.3 2.4-1.9 4.4-4.2 5.3-1 .4-2.2.6-3.5.5-2.9-.2-5.4-2.2-6.1-5 .7.5 1.7.7 2.7.7h.5c.4 0 .8-.3.8-.8v-5c0-.4.3-.8.8-.8h.6v-1c0-.8.7-1.5 1.5-1.5h1V8h.9V6.4c0-.8.7-1.5 1.5-1.5h1v2.4h.9v5.1h.8c.9 0 1.8-.2 2.6-.7Z'
  },
  {
    name: 'Instagram',
    href: 'https://www.instagram.com/lowfuel.dad/',
    path: 'M7 2h10a5 5 0 0 1 5 5v10a5 5 0 0 1-5 5H7a5 5 0 0 1-5-5V7a5 5 0 0 1 5-5Zm0 2.2A2.8 2.8 0 0 0 4.2 7v10A2.8 2.8 0 0 0 7 19.8h10a2.8 2.8 0 0 0 2.8-2.8V7A2.8 2.8 0 0 0 17 4.2H7Zm10.25 1.45a1.2 1.2 0 1 1-1.2 1.2 1.2 1.2 0 0 1 1.2-1.2ZM12 7a5 5 0 1 1-5 5 5 5 0 0 1 5-5Zm0 2.2a2.8 2.8 0 1 0 2.8 2.8A2.8 2.8 0 0 0 12 9.2Z'
  }
];
---

<footer class="bg-slate-950 py-10 text-slate-300" aria-label={isEnglish ? 'Footer' : 'Fußbereich'}>
  <div class="mx-auto flex max-w-6xl flex-col gap-6 px-6 md:flex-row md:items-center md:justify-between md:px-10 lg:px-12">
    <div>
      <p class="text-sm font-semibold text-white">Paul Scholz © 2025</p>
      <p class="mt-2 text-sm text-slate-400">
        {isEnglish
          ? 'Built with Astro & Tailwind CSS. Hosted on GitHub Pages.'
          : 'Gebaut mit Astro & Tailwind CSS. Gehostet auf GitHub Pages.'}
      </p>
    </div>

    <div class="flex flex-col gap-5 md:items-end">
      <div class="flex flex-wrap items-center gap-4 text-sm">
        <a href={isEnglish ? '/en/impressum/' : '/impressum/'} class="hover:text-white">
          {isEnglish ? 'Legal Notice' : 'Impressum'}
        </a>
        <a href={isEnglish ? '/en/datenschutz/' : '/datenschutz/'} class="hover:text-white">
          {isEnglish ? 'Privacy Policy' : 'Datenschutz'}
        </a>
      </div>

      <div class="flex items-center gap-3">
        {socials.map((social) => (
          <a
            href={social.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={social.name}
            class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-white/10 bg-white/5 text-slate-200 transition-colors hover:border-teal hover:text-teal"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5">
              <path d={social.path}></path>
            </svg>
          </a>
        ))}
      </div>
    </div>
  </div>
</footer>
