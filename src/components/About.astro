---
interface Props {
  lang?: 'de' | 'en';
}

const { lang = 'de' } = Astro.props;
const isEnglish = lang === 'en';

const content = isEnglish
  ? {
      id: 'about',
      title: 'About Me',
      lead:
        'I am Paul Scholz – IT systems administrator and SEO consultant from Germany. I manage enterprise Hyper-V and SCVMM environments with hundreds of hosts and thousands of virtual machines on a daily basis. What I do at work – solve complex, scalable problems with clean automation – I bring to every project I take on.',
      body:
        'Parallel to my enterprise work, I advise small and medium-sized businesses on local SEO, AI-assisted workflows, and digital infrastructure. I run an extensive homelab with Docker, n8n, and self-hosted services. I write about what I actually do – not about what sounds good. If you need someone who combines technical depth with practical results, that\'s where I come in.',
      asideTitle: 'Track Record',
      asideText:
        '10+ years in enterprise IT, 1,000+ VMs managed, 50+ SEO projects for local businesses across Germany.',
      tags: [
        'Enterprise IT',
        'Hyper-V/SCVMM',
        'PowerShell',
        'SEO',
        'AI',
        'Docker',
        'Python',
        'n8n',
        'Cloud'
      ]
    }
  : {
      id: 'ueber-mich',
      title: 'Über mich',
      lead:
        'Ich bin Paul Scholz – IT-Systemadministrator und SEO-Berater aus Deutschland. Im Tagesgeschäft verwalte ich Hyper-V- und SCVMM-Umgebungen mit hunderten von Hosts und tausenden virtuellen Maschinen. Was ich bei der Arbeit täglich tue – komplexe, skalierbare Probleme mit sauberer Automatisierung lösen – das bringe ich in jedes Projekt, das ich annehme.',
      body:
        'Parallel dazu berate ich kleine und mittelständische Unternehmen in lokaler SEO, KI-gestützten Workflows und digitaler Infrastruktur. Ich betreibe ein umfangreiches Homelab mit Docker, n8n und Self-Hosted-Services. Ich schreibe über das, was ich wirklich tue – nicht über das, was gut klingt. Wenn du jemanden brauchst, der technische Tiefe mit praktischen Ergebnissen verbindet, bin ich die richtige Person.',
      asideTitle: 'Nachweisliche Erfahrung',
      asideText:
        '10+ Jahre Enterprise-IT, 1.000+ VMs verwaltet, 50+ SEO-Projekte für lokale Unternehmen in Deutschland.',
      tags: [
        'Enterprise IT',
        'Hyper-V/SCVMM',
        'PowerShell',
        'SEO',
        'KI/AI',
        'Docker',
        'Python',
        'n8n',
        'Cloud'
      ]
    };
---

<section
  id={content.id}
  class="bg-white py-24 sm:py-28"
  aria-labelledby={`${content.id}-heading`}
>
  <div class="mx-auto grid max-w-6xl gap-12 px-6 md:px-10 lg:grid-cols-[1.45fr_0.95fr] lg:items-start lg:px-12">
    <div class="max-w-3xl">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-teal">
        {isEnglish ? 'Profile' : 'Profil'}
      </p>
      <h2
        id={`${content.id}-heading`}
        class="mt-4 text-3xl font-semibold tracking-tight text-navy sm:text-4xl"
      >
        {content.title}
      </h2>
      <p class="mt-6 text-lg leading-8 text-slate-700">
        {content.lead}
      </p>
      <p class="mt-6 text-base leading-8 text-slate-600">
        {content.body}
      </p>
    </div>

    <aside class="rounded-[2rem] bg-slate-50 p-8 ring-1 ring-slate-200">
      <h3 class="text-xl font-semibold text-navy">{content.asideTitle}</h3>
      <p class="mt-4 text-sm leading-7 text-slate-600">
        {content.asideText}
      </p>

      <div class="mt-8 flex flex-wrap gap-3">
        {content.tags.map((tag) => (
          <span class="rounded-full bg-white px-4 py-2 text-sm font-medium text-slate-700 ring-1 ring-slate-200">
            {tag}
          </span>
        ))}
      </div>
    </aside>
  </div>
</section>
