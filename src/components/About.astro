---
interface Props {
  lang?: 'de' | 'en';
}

const { lang = 'de' } = Astro.props;
const isEnglish = lang === 'en';

const content = isEnglish
  ? {
      id: 'about',
      title: 'About Me',
      lead:
        'I am Paul Scholz, an IT systems administrator and infrastructure specialist from Germany. With years of experience in enterprise IT environments, including Hyper-V and SCVMM platforms with hundreds of hosts and thousands of virtual machines, PowerShell automation, and VDI management, I bring deep technical expertise to every project.',
      body:
        'At the same time, I am passionate about SEO, AI-assisted automation, and digital visibility for small and medium-sized businesses. I also run an extensive homelab with Docker, self-hosting, and modern DevOps tooling. My goal is to make complex topics approachable, whether the challenge is server infrastructure, search engine optimization, or the rollout of AI tools.',
      asideTitle: 'Focus Areas',
      asideText:
        'I work best at the intersection of robust infrastructure, clear automation and visible digital outcomes.',
      tags: [
        'Enterprise IT',
        'Hyper-V/SCVMM',
        'PowerShell',
        'SEO',
        'AI',
        'Docker',
        'Python',
        'n8n',
        'Cloud'
      ]
    }
  : {
      id: 'ueber-mich',
      title: 'Über mich',
      lead:
        'Ich bin Paul Scholz, IT-Systemadministrator und Infrastruktur-Spezialist aus Deutschland. Mit jahrelanger Erfahrung in Enterprise-IT-Umgebungen, darunter Hyper-V- und SCVMM-Infrastrukturen mit hunderten Hosts und tausenden virtuellen Maschinen, PowerShell-Automatisierung und VDI-Management, bringe ich technische Tiefe in jedes Projekt.',
      body:
        'Parallel dazu beschäftige ich mich leidenschaftlich mit SEO, KI-gestützter Automatisierung und dem Thema digitale Sichtbarkeit für kleine und mittelständische Unternehmen. Ich betreibe außerdem ein umfangreiches Homelab mit Docker, Self-Hosting und modernen DevOps-Tools. Mein Ziel ist es, Komplexes einfach zu machen, egal ob es um Serverinfrastruktur, Suchmaschinenoptimierung oder die Einführung von KI-Tools geht.',
      asideTitle: 'Schwerpunkte',
      asideText:
        'Am stärksten bin ich dort, wo stabile Infrastruktur, saubere Automatisierung und messbare digitale Sichtbarkeit zusammenkommen.',
      tags: [
        'Enterprise IT',
        'Hyper-V/SCVMM',
        'PowerShell',
        'SEO',
        'KI/AI',
        'Docker',
        'Python',
        'n8n',
        'Cloud'
      ]
    };
---

<section
  id={content.id}
  class="bg-white py-24 sm:py-28"
  aria-labelledby={`${content.id}-heading`}
>
  <div class="mx-auto grid max-w-6xl gap-12 px-6 md:px-10 lg:grid-cols-[1.45fr_0.95fr] lg:items-start lg:px-12">
    <div class="max-w-3xl">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-teal">
        {isEnglish ? 'Profile' : 'Profil'}
      </p>
      <h2
        id={`${content.id}-heading`}
        class="mt-4 text-3xl font-semibold tracking-tight text-navy sm:text-4xl"
      >
        {content.title}
      </h2>
      <p class="mt-6 text-lg leading-8 text-slate-700">
        {content.lead}
      </p>
      <p class="mt-6 text-base leading-8 text-slate-600">
        {content.body}
      </p>
    </div>

    <aside class="rounded-[2rem] bg-slate-50 p-8 ring-1 ring-slate-200">
      <h3 class="text-xl font-semibold text-navy">{content.asideTitle}</h3>
      <p class="mt-4 text-sm leading-7 text-slate-600">
        {content.asideText}
      </p>

      <div class="mt-8 flex flex-wrap gap-3">
        {content.tags.map((tag) => (
          <span class="rounded-full bg-white px-4 py-2 text-sm font-medium text-slate-700 ring-1 ring-slate-200">
            {tag}
          </span>
        ))}
      </div>
    </aside>
  </div>
</section>
