---
interface Props {
  lang?: 'de' | 'en';
}

const { lang = 'de' } = Astro.props;
const isEnglish = lang === 'en';

const services = isEnglish
  ? [
      {
        title: 'Organic Visibility & SEO',
        description: 'From technical audit to content architecture: I identify where your site is losing visibility and build a measurable strategy to fix it. Local SEO, Core Web Vitals, structured data, and AI-assisted content – not guesswork, but precision work.',
        bullets: ['Technical SEO audits & prioritized action plans', 'Local SEO & Google Business optimization', 'AI-assisted content strategy & keyword architecture'],
        icon: 'M2.25 18 9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941'
      },
      {
        title: 'IT Infrastructure & Automation',
        description: 'Whether it\'s a PowerShell pipeline for 200 Hyper-V hosts, a containerized on-premises service stack, or an AI workflow that handles repetitive tasks autonomously – I design it, implement it, and document it so it actually keeps running.',
        bullets: ['Enterprise virtualization consulting (Hyper-V/SCVMM)', 'Scripted operations & process automation', 'On-premises container infrastructure & CI/CD'],
        icon: 'M6.75 7.5 3 12l3.75 4.5M17.25 7.5 21 12l-3.75 4.5M13.5 4.5l-3 15'
      },
      {
        title: 'Digital Projects & Consulting',
        description: 'Sometimes you just need someone who knows what they\'re doing. Website, infrastructure concept, AI integration, DNS headache, or simply a technical second opinion – I\'m available for projects of any size, with clear communication and no agency overhead.',
        bullets: ['Web projects with Astro, Tailwind & modern tooling', 'AI workflow integration (n8n, Claude, local LLMs)', 'Technical consulting & architecture review'],
        icon: 'M8.625 9.75a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375m-13.5 3.01c0 1.6 1.123 2.994 2.707 3.227 1.087.16 2.185.283 3.293.369V21l4.184-4.183a1.14 1.14 0 0 1 .778-.332 48.294 48.294 0 0 0 5.83-.498c1.585-.233 2.708-1.626 2.708-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0 0 12 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018Z'
      }
    ]
  : [
      {
        title: 'Organische Sichtbarkeit & SEO',
        description: 'Vom technischen Audit bis zur Content-Architektur: Ich finde heraus, wo deine Website Sichtbarkeit verliert – und baue eine messbare Strategie, das zu ändern. Lokale SEO, Core Web Vitals, strukturierte Daten und KI-gestützte Content-Strategie – kein Raten, sondern Präzisionsarbeit.',
        bullets: ['Technische SEO-Audits & priorisierte Maßnahmenpläne', 'Lokale SEO & Google Business-Optimierung', 'KI-gestützte Content-Strategie & Keyword-Architektur'],
        icon: 'M2.25 18 9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941'
      },
      {
        title: 'IT-Infrastruktur & Automatisierung',
        description: 'Ob PowerShell-Pipeline für 200 Hyper-V-Hosts, containerisiertes On-Premises-Service-Stack oder KI-Workflow der repetitive Aufgaben eigenständig erledigt – ich konzipiere es, setze es um und dokumentiere es so, dass es auch wirklich läuft.',
        bullets: ['Enterprise-Virtualisierungsberatung (Hyper-V/SCVMM)', 'Skriptbasierter Betrieb & Prozessautomatisierung', 'On-Premises-Container-Infrastruktur & CI/CD'],
        icon: 'M6.75 7.5 3 12l3.75 4.5M17.25 7.5 21 12l-3.75 4.5M13.5 4.5l-3 15'
      },
      {
        title: 'Digitalprojekte & Beratung',
        description: 'Manchmal braucht man einfach jemanden, der weiß was er tut. Website, Infrastrukturkonzept, KI-Integration, DNS-Problem oder eine technische Zweitmeinung – ich bin für Projekte jeder Größe verfügbar, mit klarer Kommunikation und ohne Agentur-Overhead.',
        bullets: ['Webprojekte mit Astro, Tailwind & modernem Stack', 'KI-Workflow-Integration (n8n, Claude, lokale LLMs)', 'Technische Beratung & Architektur-Review'],
        icon: 'M8.625 9.75a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375m-13.5 3.01c0 1.6 1.123 2.994 2.707 3.227 1.087.16 2.185.283 3.293.369V21l4.184-4.183a1.14 1.14 0 0 1 .778-.332 48.294 48.294 0 0 0 5.83-.498c1.585-.233 2.708-1.626 2.708-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0 0 12 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018Z'
      }
    ];
---

<section
  id={isEnglish ? 'services' : 'leistungen'}
  class="bg-slate-50 py-24 sm:py-28"
  aria-labelledby="services-heading"
>
  <div class="mx-auto max-w-6xl px-6 md:px-10 lg:px-12">
    <p class="text-sm font-semibold uppercase tracking-[0.24em] text-teal">
      {isEnglish ? 'Services' : 'Leistungen'}
    </p>
    <h2 id="services-heading" class="mt-4 text-3xl font-semibold tracking-tight text-navy sm:text-4xl">
      {isEnglish ? 'Pragmatic support for modern digital projects' : 'Pragmatische Unterstützung für moderne Digitalprojekte'}
    </h2>

    <div class="mt-12 grid gap-6 lg:grid-cols-3">
      {services.map((service, index) => (
        <article
          class="group rounded-[2rem] bg-white p-8 shadow-lg shadow-slate-200/60 ring-1 ring-slate-200 transition-all duration-300 hover:-translate-y-1.5 hover:shadow-2xl hover:shadow-slate-300/40"
        >
          <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-teal/10 text-teal">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" class="h-7 w-7">
              <path stroke-linecap="round" stroke-linejoin="round" d={service.icon}></path>
            </svg>
          </div>
          <h3 class="mt-6 text-xl font-semibold text-navy">
            {service.title}
          </h3>
          <p class="mt-4 text-sm leading-7 text-slate-600">
            {service.description}
          </p>
          <ul class="mt-5 space-y-2">
            {service.bullets.map((bullet) => (
              <li class="flex items-start gap-2.5 text-sm text-slate-600">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-teal" viewBox="0 0 16 16" fill="currentColor">
                  <path fill-rule="evenodd" d="M12.416 3.376a.75.75 0 0 1 .208 1.04l-5 7.5a.75.75 0 0 1-1.154.114l-3-3a.75.75 0 0 1 1.06-1.06l2.353 2.353 4.493-6.74a.75.75 0 0 1 1.04-.207Z" clip-rule="evenodd" />
                </svg>
                <span>{bullet}</span>
              </li>
            ))}
          </ul>
          <p class="mt-6 text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">
            0{index + 1}
          </p>
        </article>
      ))}
    </div>

    <p class="mt-10 text-sm font-medium text-slate-600">
      {isEnglish
        ? 'All services on request. I create individual proposals.'
        : 'Alle Leistungen auf Anfrage. Ich erstelle individuelle Angebote.'}
    </p>
  </div>
</section>
